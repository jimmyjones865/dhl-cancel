# Environment: "eu" for production, "sandbox" for testing
DHL_ENV=sandbox

# DHL Geschäftskundenportal (GKP) credentials
DHL_USER=user-valid
DHL_PASSWORD=SandboxPasswort2023!

# DHL API app credentials (from https://developer.dhl.com)
DHL_API_KEY=
DHL_API_SECRET=

# Shipping profile (rarely needs changing)
DHL_PROFILE=STANDARD_GRUPPENPROFIL

# Port the service listens on (inside the container)
PORT=8080
